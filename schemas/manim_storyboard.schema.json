{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ManimStoryboard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "deck_id",
    "language",
    "theme",
    "video",
    "scenes"
  ],
  "properties": {
    "deck_id": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "object"
    },
    "video": {
      "type": "object",
      "required": [
        "aspect_ratio",
        "pixel_width",
        "pixel_height",
        "frame_rate",
        "preview_scale"
      ],
      "properties": {
        "aspect_ratio": {
          "type": "string",
          "minLength": 1
        },
        "pixel_width": {
          "type": "integer",
          "minimum": 1
        },
        "pixel_height": {
          "type": "integer",
          "minimum": 1
        },
        "frame_rate": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "preview_scale": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scene_id",
          "template",
          "title",
          "voiceover",
          "data"
        ],
        "properties": {
          "scene_id": {
            "type": "string",
            "minLength": 1
          },
          "template": {
            "type": "string",
            "enum": [
              "title_bullets",
              "definition_math",
              "example_walkthrough",
              "graph_focus",
              "procedure_steps",
              "recap_cards"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "voiceover": {
            "type": "string",
            "minLength": 1
          },
          "hook": {
            "type": "string",
            "minLength": 1
          },
          "disabled": {
            "type": "boolean"
          },
          "timing": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "lead_in_seconds": {
                "type": "number",
                "minimum": 0
              },
              "hold_after_seconds": {
                "type": "number",
                "minimum": 0
              },
              "minimum_duration_seconds": {
                "type": "number",
                "minimum": 0
              }
            }
          },
          "data": {
            "type": "object"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "template": {
                  "const": "title_bullets"
                }
              }
            },
            "then": {
              "properties": {
                "data": {
                  "type": "object",
                  "required": [
                    "bullets"
                  ],
                  "properties": {
                    "bullets": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "template": {
                  "const": "definition_math"
                }
              }
            },
            "then": {
              "properties": {
                "data": {
                  "type": "object",
                  "required": [
                    "statement",
                    "math_lines"
                  ],
                  "properties": {
                    "statement": {
                      "type": "string"
                    },
                    "math_lines": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "template": {
                  "const": "example_walkthrough"
                }
              }
            },
            "then": {
              "properties": {
                "data": {
                  "type": "object",
                  "required": [
                    "steps",
                    "takeaway"
                  ],
                  "properties": {
                    "steps": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "takeaway": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "template": {
                  "const": "graph_focus"
                }
              }
            },
            "then": {
              "properties": {
                "data": {
                  "type": "object",
                  "required": [
                    "axes",
                    "plots",
                    "annotations"
                  ],
                  "properties": {
                    "axes": {
                      "type": "object",
                      "required": [
                        "x_range",
                        "y_range",
                        "x_length",
                        "y_length"
                      ]
                    },
                    "plots": {
                      "type": "array"
                    },
                    "annotations": {
                      "type": "array"
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "template": {
                  "const": "procedure_steps"
                }
              }
            },
            "then": {
              "properties": {
                "data": {
                  "type": "object",
                  "required": [
                    "steps",
                    "worked_equations"
                  ],
                  "properties": {
                    "steps": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "worked_equations": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "template": {
                  "const": "recap_cards"
                }
              }
            },
            "then": {
              "properties": {
                "data": {
                  "type": "object",
                  "required": [
                    "points",
                    "identities"
                  ],
                  "properties": {
                    "points": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "identities": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        ]
      }
    }
  }
}
